{
  "name": "@scaledown/claude-plugin",
  "version": "0.3.1",
  "description": "Claude Code plugin for Scaledown AI context optimization",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "scaledown-claude": "./dist/bin/setup.js",
    "scaledown-claude-hook": "./dist/hooks/user-prompt-submit.js",
    "scaledown-claude-post-tool-use": "./dist/hooks/post-tool-use.js",
    "scaledown-claude-git-attribution": "./dist/hooks/git-attribution.js",
    "scaledown-claude-status": "./dist/hooks/status.js",
    "scaledown-claude-reconcile": "./dist/bin/postinstall.js"
  },
  "main": "./dist/src/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node ./dist/bin/postinstall.js || true",
    "test": "jest --testPathIgnorePatterns='/node_modules/' --testPathIgnorePatterns='real-api'",
    "test:unit": "jest --testPathPattern='(client|niah|post-tool-use|user-prompt-submit)\\.test'",
    "test:integration": "jest --testPathPattern='(integration|mcp-contract)\\.test'",
    "test:config": "jest --testPathPattern='config-formats\\.test'",
    "test:hooks": "jest --testPathPattern='hook-integration\\.test' --testTimeout=120000",
    "test:real": "jest --testPathPattern='real-api\\.test'",
    "start": "node dist/src/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "diagnostics": {
            "ignoreCodes": [
              "TS151002"
            ]
          }
        }
      ]
    }
  }
}
